FROM docker.io/eclipse-temurin:17.0.19_10-jdk-noble@sha256:6135b2dcc36fc4df1e534fc39113722e412799ffdb9ec0ed914ffce366f235c5 AS base

# Stage 1: base
# Minimal environment with only system tools. This stage is stable and reusable across merges.

RUN apt-get install -y --no-install-recommends --update \
      fd-find \
      git \
      ripgrep \
      rustup \
      unzip \
      python3 \
 && rm -rf /var/lib/apt/lists/*

# Set a default Git identity
RUN git config --global user.name "builder" \
 && git config --global user.email "builder@docker.local"

FROM base AS builder

# Stage 2: builder
# Adds toolchains, project source, and the build entrypoint.

LABEL im.molly.artifacts.m2.path="/root/.m2/repository/"

# Install Android SDK
ARG ANDROID_SDK_DIST="commandlinetools-linux-13114758_latest.zip"
ARG ANDROID_SDK_SHA256="7ec965280a073311c339e571cd5de778b9975026cfcbe79f2b1cdcb1e15317ee"
ENV ANDROID_HOME=/opt/android-sdk
ENV PATH="$PATH:$ANDROID_HOME/cmdline-tools/latest/bin"

RUN set -eux; \
    curl -fS "https://dl.google.com/android/repository/$ANDROID_SDK_DIST" -o sdk.zip; \
    printf '%s  %s\n' "$ANDROID_SDK_SHA256" "sdk.zip" | sha256sum -c; \
    mkdir -p "$ANDROID_HOME"; \
    unzip -q sdk.zip -d "$ANDROID_HOME/cmdline-tools/"; \
    rm sdk.zip; \
    mv "$ANDROID_HOME/cmdline-tools/cmdline-tools" "$ANDROID_HOME/cmdline-tools/latest"; \
    yes | sdkmanager --licenses; \
    sdkmanager "platform-tools"

ARG NDK_VERSION="28.0.13004108"
RUN sdkmanager "ndk;$NDK_VERSION"

ENV ANDROID_NDK_HOME="$ANDROID_HOME/ndk/$NDK_VERSION"

ARG BUILD_TOOLS_VERSION="36.0.0"
RUN sdkmanager "build-tools;${BUILD_TOOLS_VERSION}"

ARG COMPILE_SDK="android-34"
RUN sdkmanager "platforms;${COMPILE_SDK}"

# Bootstrap depot_tools
ARG DEPOT_TOOLS_GIT_HASH="57d50b8656bfed9e42adf8de1d549ba4229cc909"
ENV DEPOT_TOOLS_UPDATE=0
ENV PATH="$PATH:/opt/depot_tools"
RUN set -eux; \
    git clone https://chromium.googlesource.com/chromium/tools/depot_tools.git /opt/depot_tools; \
    cd /opt/depot_tools; \
    git checkout -b docker-build "$DEPOT_TOOLS_GIT_HASH^{commit}"; \
    rm -rf .git; \
    ensure_bootstrap

# Install build tools pinned to a fixed timestamp via snapshot service
ARG APT_SNAPSHOT_ID=20260703T000000Z
RUN apt-get update --snapshot "$APT_SNAPSHOT_ID" \
 && apt-get install -y --no-install-recommends \
      clang \
      pkg-config \
      protobuf-compiler \
      xz-utils \
 && rm -rf /var/lib/apt/lists/*

## Cache gradle wrapper
COPY gradlew /ringrtc/
COPY gradle/wrapper /ringrtc/gradle/wrapper
RUN /ringrtc/gradlew --version

# Set optional read-only Gradle cache (mount at runtime)
ENV GRADLE_RO_DEP_CACHE=/.gradle-ro-cache

# Install Rust toolchain and targets
COPY rust-toolchain /ringrtc/
RUN rustup toolchain install "$(cat /ringrtc/rust-toolchain)" --profile minimal \
      --target aarch64-linux-android \
      --target armv7-linux-androideabi \
      --target x86_64-linux-android \
      --no-self-update

# Sync external dependencies
COPY bin/prepare-workspace bin/env.sh bin/env-android.sh bin/gsync-webrtc /ringrtc/bin/
COPY config /ringrtc/config
RUN /ringrtc/bin/prepare-workspace android

# Copy project and purge generated files
COPY . /ringrtc/
WORKDIR /ringrtc
RUN git clean -ffdx -e "out/" -e "src/webrtc*"

# Build entrypoint
RUN cat <<'EOF' > build.sh && chmod +x build.sh
#!/bin/sh
set -eu
usage() {
  echo "Usage: build.sh [test|install|publish]... [-- args...]"
}
build_aar() {
  ./bin/build-aar --arch arm arm64 x64 --jobs "$(nproc)" "$@"
}
cmds=
while [ $# -gt 0 ]; do
  case "$1" in
    test|install|publish) cmds="${cmds:+$cmds }$1" ;;
    -h|--help) usage; exit 0 ;;
    --) shift; break ;;
    *) echo "unknown command: $1" >&2; usage >&2; exit 2 ;;
  esac
  shift
done
[ -n "$cmds" ] || { usage; exit 0; }
for c in $cmds; do
  case "$c" in
    test)
      (cd src/rust && ./scripts/run-tests)
      ;;
    install)
      build_aar --install-local "$@"
      ;;
    publish)
      build_aar --publish "$@"
      ;;
  esac
done
EOF

ENTRYPOINT ["/ringrtc/build.sh"]
CMD ["help"]
